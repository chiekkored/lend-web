# Admin app host used for generated links and routing.
NEXT_PUBLIC_ADMIN_HOST=admin.<base_url_here>.com

# Set true only when the admin app should use local Firebase emulators.
NEXT_PUBLIC_FIREBASE_USE_EMULATORS=true

# Firebase web app config.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Callable/HTTP function URLs used by admin management flows.
NEXT_PUBLIC_ADMIN_BOOTSTRAP_FUNCTION_URL=
NEXT_PUBLIC_ADMIN_CREATE_ADMIN_FUNCTION_URL=
NEXT_PUBLIC_ADMIN_UPDATE_ADMIN_FUNCTION_URL=
NEXT_PUBLIC_ADMIN_DELETE_ADMIN_FUNCTION_URL=

# Local-only secret used by local registration/bootstrap tooling.
LOCAL_REGISTER_SECRET=replace-with-local-register-secret
